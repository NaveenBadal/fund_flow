<?xml version="1.0" encoding="utf-8"?>
<!--
  Fund Flow launcher background.
  Deep Midnight canvas with a soft indigo glow behind the mark, giving the
  adaptive icon depth without competing with the foreground.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp" android:height="108dp"
    android:viewportWidth="108" android:viewportHeight="108">
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial"
                android:centerX="52" android:centerY="48"
                android:gradientRadius="78">
                <item android:offset="0" android:color="#1E1A3C" />
                <item android:offset="0.55" android:color="#12111F" />
                <item android:offset="1" android:color="#0B0C11" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
